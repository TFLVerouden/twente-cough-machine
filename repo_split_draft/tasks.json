{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "submodules: init/update",
      "type": "shell",
      "command": "git submodule sync --recursive && git submodule update --init --recursive",
      "group": "build"
    },
    {
      "label": "host: install editable",
      "type": "shell",
      "command": "python -m pip install -e ./utils && python -m pip install -e ./control",
      "group": "build"
    },
    {
      "label": "host: run cough",
      "type": "shell",
      "command": "python -m tcm_control.cough",
      "options": {
        "cwd": "${workspaceFolder:control}/source_python"
      },
      "group": "test"
    },
    {
      "label": "firmware: build",
      "type": "shell",
      "command": "pio run",
      "options": {
        "cwd": "${workspaceFolder:firmware}"
      },
      "group": "build"
    },
    {
      "label": "firmware: upload",
      "type": "shell",
      "command": "pio run -t upload",
      "options": {
        "cwd": "${workspaceFolder:firmware}"
      },
      "group": "build"
    }
  ]
}
